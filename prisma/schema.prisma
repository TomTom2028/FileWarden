// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum FilecheckResult {
  PASS
  FAIL

  @@map("filecheck_result")
}

model CachedResult {
  hash      Bytes                    @id
  result    FilecheckResult
  firstSeen DateTime                 @default(now()) @map("first_seen")
  history   FilecheckResultHistory[]

  @@map("cached_result")
}

model FilecheckResultHistory {
  id        Int          @id @default(autoincrement())
  fileName  String       @map("file_name")
  timestamp DateTime     @default(now())
  hash      Bytes
  cached    CachedResult @relation(fields: [hash], references: [hash])

  @@index([fileName])
  @@index([hash])
  @@index([timestamp])
  @@map("filecheck_result_history")
}
