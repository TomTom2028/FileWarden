// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum FilecheckResultValue {
  PASS
  FAIL
  UNKNOWN

  @@map("filecheck_result_value")
}

model CachedResult {
  hash      Bytes                @id
  result    FilecheckResultValue
  firstSeen DateTime             @default(now()) @map("first_seen")
  history   FilecheckResult[]

  @@map("cached_result")
}

model FilecheckResult {
  id        Int          @id @default(autoincrement())
  filePath  String       @map("file_path")
  timestamp DateTime     @default(now())
  hash      Bytes
  cached    CachedResult @relation(fields: [hash], references: [hash])

  @@index([filePath])
  @@index([hash])
  @@index([timestamp])
  @@map("filecheck_result")
}
