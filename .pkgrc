{
	"scripts": "build/**/*.js",
	"assets": [
		"input/**/*",
		"prisma/migrations/**/*",
		"node_modules/better-sqlite3/build/Release/*.node"
	],
	"targets": [
		"node24-win-x64",
		"node24-linux-x64"
	],
	"outputPath": "dist",
	"ignore": [
		"**/*.ts",
		"**/*.map",
		"node_modules/**",
		"src/**",
		"build/types/**"
	]
}
